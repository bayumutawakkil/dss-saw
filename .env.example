# Supabase Configuration - Private (Server-side only)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Configuration - Public (Client-side)
# Must be prefixed with NEXT_PUBLIC_ to be accessible from client-side code
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# These variables are required for authentication to work
# Get them from your Supabase project dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings → API
# 4. Copy the Project URL and anon (public) key
